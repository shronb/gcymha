body {
  font-family: Arial, sans-serif;
  background-color: #f2f6fa;
  color: #333;
  margin: 0;
  padding: 0;
}

header {
  background-color: #004d7a;
  color: white;
  padding: 1em;
  text-align: center;
}

nav {
  margin-top: 0.5em;
}

nav a {
  color: white;
  text-decoration: none;
  margin: 0 10px;
}

main {
  padding: 2em;
  max-width: 800px;
  margin: auto;
}

footer {
  background-color: #e0e0e0;
  text-align: center;
  padding: 1em;
  margin-top: 2em;
}
